<section class="others-showcase">
  <p class="others-kicker">Chef Highlight</p>
  <h1 class="menu-title">Others</h1>
  <p class="others-intro">Special feature from our kitchen this week with bold flavor and signature finishing sauces.</p>

  <article class="feature-dish-card">
    <div class="feature-dish-visual">
      <img src="/images/side_chicken_1.jpg" alt="Side shawarma chicken dish plate" loading="lazy">
    </div>
    <div class="feature-dish-content">
      <h2>AL Yamani Signature Plate</h2>
      <p>
        A rich, oven-finished plate layered with melted cheese, fresh toppings, and balanced spices.
        Served with garlic cream and spicy house sauce for extra flavor.
      </p>
      {{#if featuredItem}}
      <p><strong>Cart Item:</strong> {{featuredItem.name}} (Small: {{formatCurrency featuredItem.price_small}})</p>
      {{/if}}
      <ul class="feature-dish-list">
        <li>Freshly baked and plated to order</li>
        <li>Garlic sauce and spicy red sauce included</li>
        <li>Best paired with a cold fresh juice</li>
      </ul>
      <div class="feature-deals">
        <h3>Today's Deals</h3>
        <p class="deal-item">
          <span class="deal-badge">15% OFF</span>
          Signature plate from 4:00 PM to 7:00 PM.
        </p>
        <p class="deal-item">
          <span class="deal-badge">Combo</span>
          Add any fresh juice for only +6 SAR.
        </p>
        <p class="deal-item">
          <span class="deal-badge">Free Dip</span>
          Extra garlic sauce on all shawarma side orders.
        </p>
      </div>
      {{#if featuredItem}}
      <form method="POST" action="/cart/add/{{featuredItem.id}}" class="feature-order-form">
        <input type="hidden" name="size" value="small">
        <button class="btn" type="submit">Order This Dish</button>
      </form>
      {{else}}
      <a class="btn" href="/menu">Order This Dish</a>
      {{/if}}
    </div>
  </article>
</section>
