<section class="cart-page">
  <h1 class="menu-title">Your Cart</h1>

  {{#if items.length}}
    <div class="cart-shell">
      <div class="cart-table-wrap">
        <table class="cart-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Size</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            {{#each items}}
              <tr>
                <td class="item-name">{{name}}</td>
                <td><span class="size-pill">{{size}}</span></td>
                <td>{{formatCurrency unit_price}}</td>
                <td>
                  <div class="qty-controls">
                    <form method="POST" action="/cart/decrease/{{id}}" class="inline-form">
                      <button type="submit" class="qty-btn">-</button>
                    </form>
                    <span class="qty-value">{{quantity}}</span>
                    <form method="POST" action="/cart/increase/{{id}}" class="inline-form">
                      <button type="submit" class="qty-btn">+</button>
                    </form>
                  </div>
                </td>
                <td>
                  <form method="POST" action="/cart/delete/{{id}}" class="inline-form">
                    <button type="submit" class="delete-btn">Delete</button>
                  </form>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <aside class="cart-summary">
        <h2>Order Summary</h2>
        <p><span>Tax</span><strong>{{formatCurrency tax}}</strong></p>
        <p class="summary-total"><span>Total</span><strong>{{formatCurrency total}}</strong></p>
      </aside>
    </div>
    <div class="cart-actions">
      <a class="btn continue-shopping-btn" href="/menu">Continue Shopping</a>
      <a class="btn checkout-btn" href="/cart/checkout">Checkout</a>
    </div>
  {{else}}
    <div class="cart-empty">
      <p>Your cart is empty.</p>
      <a class="btn" href="/menu">Browse menu</a>
    </div>
  {{/if}}
</section>
