<h1 class="menu-title">Our Menu</h1>
<nav class="menu-category-links" aria-label="Menu categories">
  {{#each categories}}
    <a href="#{{slug}}">{{name}}</a>
  {{/each}}
</nav>
{{#each categories}}
  <section class="menu-section" id="{{slug}}" data-category="{{name}}">
    <div class="card-grid">
      {{#each items}}
        <article class="card menu-card">
          <div class="menu-card-media">
            <img src="{{image_url}}" alt="{{name}}" />
          </div>
          <div class="menu-card-content">
            <div class="menu-card-body">
              <p class="name">{{name}}</p>
            </div>
            <div class="menu-card-buttons">
              <a class="btn menu-view-details" href="/menu/item/{{id}}">View Details</a>
              {{#if disableAddToCart}}
                {{!-- Keep only View Details --}}
              {{else}}
                {{#if is_single_price}}
                  <form method="POST" action="/cart/add/{{id}}" class="inline-form size-form">
                    <input type="hidden" name="size" value="small" />
                    <button class="btn" type="submit">Add to Cart</button>
                  </form>
                {{else}}
                  {{#if price_medium}}
                    {{!-- Multiple sizes: keep only View Details --}}
                  {{else}}
                    {{#if price_large}}
                      {{!-- Multiple sizes: keep only View Details --}}
                    {{else}}
                      {{#if price_xlarge}}
                        <form method="POST" action="/cart/add/{{id}}" class="inline-form size-form">
                          <input type="hidden" name="size" value="xlarge" />
                          <button class="btn" type="submit">Add to Cart</button>
                        </form>
                      {{else}}
                        <form method="POST" action="/cart/add/{{id}}" class="inline-form size-form">
                          <input type="hidden" name="size" value="small" />
                          <button class="btn" type="submit">Add to Cart</button>
                        </form>
                      {{/if}}
                    {{/if}}
                  {{/if}}
                {{/if}}
              {{/if}}
            </div>
          </div>
        </article>
      {{else}}
        <p>No items found in this category.</p>
      {{/each}}
    </div>
  </section>
{{/each}}
