<h1 class="menu-title">Our Menu</h1>
{{#each categories}}
  <section class="menu-section">
    <h2>{{name}}</h2>
    <div class="card-grid">
      {{#each items}}
        <article class="card">
          <img src="{{image_url}}" alt="{{name}}" />
          <h3>{{name}}</h3>
          <p>{{ingredients}}</p>
          <p>Small: {{formatCurrency price_small}} | Large: {{formatCurrency price_large}}</p>
          <a class="btn" href="/menu/item/{{id}}">View Details</a>
        </article>
      {{else}}
        <p>No items found in this category.</p>
      {{/each}}
    </div>
  </section>
{{/each}}

