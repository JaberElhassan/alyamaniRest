<script>
  (() => {
    const track = document.getElementById('foodSliderTrack');
    const prev = document.getElementById('sliderPrev');
    const next = document.getElementById('sliderNext');
    const toggle = document.getElementById('sliderToggle');
    if (!track || !prev || !next || !toggle) return;
    if (!track.querySelector('.slide-card')) return;

    let loopWidth = track.scrollWidth;
    let animationId = null;
    let lastFrameTime = null;
    let resumeTimeoutId = null;
    let isPaused = false;
    const speedPxPerSecond = 120;
    const supportsHoverPause = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

    const getMaxScroll = () => Math.max(loopWidth - track.clientWidth, 0);

    const refreshMetrics = () => {
      loopWidth = track.scrollWidth;
    };

    const clampScroll = () => {
      const maxScroll = getMaxScroll();
      if (track.scrollLeft > maxScroll) {
        track.scrollLeft = maxScroll;
      } else if (track.scrollLeft < 0) {
        track.scrollLeft = 0;
      }
    };

    const startAutoScroll = () => {
      if (isPaused) return;
      if (animationId) return;
      if (resumeTimeoutId) {
        clearTimeout(resumeTimeoutId);
        resumeTimeoutId = null;
      }

      const tick = (time) => {
        if (lastFrameTime == null) {
          lastFrameTime = time;
        }

        const deltaSeconds = Math.min((time - lastFrameTime) / 1000, 0.05);
        lastFrameTime = time;
        const maxScroll = getMaxScroll();
        if (maxScroll <= 0) {
          animationId = requestAnimationFrame(tick);
          return;
        }

        let nextLeft = track.scrollLeft + speedPxPerSecond * deltaSeconds;
        if (nextLeft >= maxScroll - 1) {
          track.scrollLeft = 0;
          animationId = requestAnimationFrame(tick);
          return;
        }

        track.scrollLeft = nextLeft;
        animationId = requestAnimationFrame(tick);
      };

      animationId = requestAnimationFrame(tick);
    };

    const stopAutoScroll = () => {
      if (!animationId) return;
      cancelAnimationFrame(animationId);
      animationId = null;
      lastFrameTime = null;
    };

    const scheduleResume = (delayMs = 600) => {
      if (isPaused) return;
      if (resumeTimeoutId) {
        clearTimeout(resumeTimeoutId);
      }
      resumeTimeoutId = setTimeout(() => {
        startAutoScroll();
      }, delayMs);
    };

    const getStepSize = () => {
      const firstCard = track.querySelector('.slide-card');
      if (!firstCard) return 260;
      const gap = parseFloat(window.getComputedStyle(track).columnGap) || 0;
      return firstCard.getBoundingClientRect().width + gap;
    };

    const moveOneCard = (direction) => {
      stopAutoScroll();
      clampScroll();
      const step = getStepSize();
      const current = track.scrollLeft;
      const currentIndex = Math.round(current / step);
      let targetIndex = currentIndex + direction;
      const maxIndex = Math.max(Math.floor(getMaxScroll() / step), 0);

      if (targetIndex < 0) targetIndex = maxIndex;
      if (targetIndex > maxIndex) targetIndex = 0;

      let target = targetIndex * step;
      if (target > getMaxScroll()) target = getMaxScroll();

      track.scrollTo({ left: target, behavior: 'smooth' });
      scheduleResume(700);
    };

    window.addEventListener('resize', () => {
      refreshMetrics();
      clampScroll();
    });

    track.querySelectorAll('img').forEach((img) => {
      if (!img.complete) {
        img.addEventListener('load', refreshMetrics, { once: true });
      }
    });

    if (supportsHoverPause) {
      track.addEventListener('mouseenter', stopAutoScroll);
      track.addEventListener('mouseleave', startAutoScroll);
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        stopAutoScroll();
      } else {
        startAutoScroll();
      }
    });

    prev.addEventListener('click', () => moveOneCard(-1));
    next.addEventListener('click', () => moveOneCard(1));
    toggle.addEventListener('click', () => {
      isPaused = !isPaused;
      if (isPaused) {
        stopAutoScroll();
        toggle.setAttribute('aria-label', 'Start slider');
        toggle.setAttribute('aria-pressed', 'true');
        toggle.querySelector('.slider-toggle-icon').textContent = '>';
      } else {
        toggle.setAttribute('aria-label', 'Pause slider');
        toggle.setAttribute('aria-pressed', 'false');
        toggle.querySelector('.slider-toggle-icon').textContent = '||';
        startAutoScroll();
      }
    });

    refreshMetrics();
    startAutoScroll();
  })();
</script>
