<section class="admin-wrap">
  <h1>Admin</h1>
  <p class="admin-welcome">Welcome, <strong>{{username}}</strong>.</p>
  <div class="admin-logout-form">
    <a class="btn checkout-secondary-btn" href="/logout">Logout</a>
  </div>

  <h2>Transactions</h2>

  {{#if orders.length}}
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th>Order Number</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Order Type</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each orders}}
            <tr>
              <td>{{this.orderNumber}}</td>
              <td>{{this.date}}</td>
              <td>{{#if this.customerName}}{{this.customerName}}{{else}}--{{/if}}</td>
              <td>{{#if this.orderType}}{{this.orderType}}{{else}}--{{/if}}</td>
              <td>{{formatCurrency this.total}}</td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p>No transactions yet.</p>
  {{/if}}

  <div class="admin-totals">
    <p>Pickup total: <strong>{{formatCurrency pickupTotalSum}}</strong></p>
    <p>Delivery total: <strong>{{formatCurrency deliveryTotalSum}}</strong></p>
    <p>All orders total: <strong>{{formatCurrency overallTotalSum}}</strong></p>
  </div>

  <form
    class="admin-clear-form"
    method="POST"
    action="/admin/clear-transactions"
    onsubmit="return confirm('Delete all transactions?');"
  >
    <button class="btn admin-clear-btn" type="submit">Delete All Transactions</button>
  </form>
</section>

<script>
  let currentOrdersVersion = '{{ordersVersion}}';

  window.addEventListener('storage', (event) => {
    if (event.key === 'adminOrdersUpdatedAt' && document.visibilityState === 'visible') {
      window.location.reload();
    }
  });

  const checkOrdersVersion = async () => {
    if (document.visibilityState !== 'visible') {
      return;
    }

    try {
      const response = await fetch('/admin/orders-version', {
        method: 'GET',
        headers: { Accept: 'application/json' },
        cache: 'no-store'
      });

      if (response.status === 401) {
        window.location.href = '/login';
        return;
      }

      if (!response.ok) {
        return;
      }

      const data = await response.json();
      const nextVersion = String(data.token || '');

      if (nextVersion && nextVersion !== currentOrdersVersion) {
        window.location.reload();
      }
    } catch (error) {
      // Ignore transient network issues and retry on next interval.
    }
  };

  setInterval(() => {
    checkOrdersVersion();
  }, {{adminPollIntervalMs}});
</script>
