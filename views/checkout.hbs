<section class="checkout-page-wrap">
  <h1>Checkout</h1>
  <p class="checkout-intro">Review your order and place it now.</p>

  <form method="POST" action="/cart/checkout" class="checkout-form">
    <input type="hidden" name="order_time_client" id="orderTimeInput" value="">
    <div class="checkout-shell">
      <div class="checkout-items">
        <h2>Items</h2>
        <ul class="checkout-item-list">
          {{#each items}}
            <li class="checkout-item-row">
            <span>{{name}} ({{#if size_label}}{{size_label}}{{else}}Regular{{/if}}) x {{quantity}}</span>
              <strong>{{calcSubtotal unit_price quantity}}</strong>
            </li>
          {{/each}}
        </ul>

        <div class="pickup-fields" id="deliveryFields">
          <h2 class="customer-info-title">Customer Information</h2>
          <label for="deliveryName">Name</label>
          <input id="deliveryName" name="delivery_name" type="text" autocomplete="name" required>

          <label for="deliveryPhone">Phone</label>
          <input id="deliveryPhone" name="delivery_phone" type="tel" autocomplete="tel" required>

          <label for="deliveryAddress">Address</label>
          <textarea id="deliveryAddress" name="delivery_address" rows="2" autocomplete="street-address" required></textarea>
        </div>
      </div>

      <aside class="checkout-summary">
        <h2>Payment Summary</h2>
        <p><span>Subtotal</span><strong>{{formatCurrency subtotal}}</strong></p>
        <p><span>Tax</span><strong>{{formatCurrency tax}}</strong></p>
        <p class="summary-total"><span>Total</span><strong>{{formatCurrency total}}</strong></p>

        <div class="order-type">
          <p class="order-type-title">Order Type</p>
          <label class="order-type-option">
            <input type="radio" name="order_type" value="delivery" checked>
            Delivery
          </label>
          <label class="order-type-option">
            <input type="radio" name="order_type" value="pickup">
            Pickup
          </label>
        </div>

        <button class="btn" type="submit">Place Order</button>
      </aside>
    </div>
  </form>
</section>

<script>
  (() => {
    const orderTimeInput = document.getElementById('orderTimeInput');
    const checkoutForm = document.querySelector('.checkout-form');
    const orderTypeInputs = document.querySelectorAll('input[name="order_type"]');
    const addressField = document.getElementById('deliveryAddress');
    const addressLabel = document.querySelector('label[for="deliveryAddress"]');
    if (!orderTimeInput) return;

    const updateAddressVisibility = () => {
      if (!addressField || !addressLabel || !orderTypeInputs.length) return;
      const selected = document.querySelector('input[name="order_type"]:checked');
      const isPickup = selected && selected.value === 'pickup';
      addressField.classList.toggle('is-hidden', isPickup);
      addressLabel.classList.toggle('is-hidden', isPickup);
      if (isPickup) {
        addressField.removeAttribute('required');
      } else {
        addressField.setAttribute('required', 'required');
      }
    };

    const setOrderTime = () => {
      const nowLabel = new Date().toLocaleString();
      if (orderTimeInput) orderTimeInput.value = nowLabel;
    };

    orderTypeInputs.forEach((input) => {
      input.addEventListener('change', updateAddressVisibility);
    });

    updateAddressVisibility();
    setOrderTime();

    if (checkoutForm) {
      checkoutForm.addEventListener('submit', () => {
        setOrderTime();
      });
    }
  })();
</script>
