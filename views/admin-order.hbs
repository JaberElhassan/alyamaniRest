<section class="admin-wrap">
  <h1>Order {{order.orderNumber}}</h1>
  <p><strong>Date:</strong> {{order.date}}</p>
  <p><strong>Customer:</strong> {{#if order.customerName}}{{order.customerName}}{{else}}--{{/if}}</p>
  <p><strong>Order Type:</strong> {{#if order.orderType}}{{order.orderType}}{{else}}--{{/if}}</p>
  <p><strong>Total:</strong> {{formatCurrency order.total}}</p>

  <h2>Items</h2>
  {{#if order.items.length}}
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Size</th>
          <th>Quantity</th>
          <th>Line Total</th>
        </tr>
      </thead>
      <tbody>
        {{#each order.items}}
          <tr>
            <td>{{name}}</td>
            <td>{{#if size_label}}{{size_label}}{{else}}Regular{{/if}}</td>
            <td>{{quantity}}</td>
            <td>{{calcSubtotal unit_price quantity}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p>No items recorded for this order.</p>
  {{/if}}

  <div class="checkout-success-actions">
    <a class="btn checkout-secondary-btn" href="/admin">Back to Admin</a>
  </div>
</section>
