<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}} | AL YAMANI RESTAURANT</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="{{bodyClass}}">
  <header class="site-header">
    <a class="brand" href="/" aria-label="AL YAMANI RESTAURANT home">
      <img src="/images/logo.svg" alt="AL YAMANI RESTAURANT logo" class="brand-logo" />
      <span class="brand-text">AL YAMANI RESTAURANT</span>
    </a>
    <button class="menu-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-navbar">
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
      <span class="menu-toggle-bar"></span>
    </button>
    <a href="/cart" class="cart-mobile-icon" aria-label="Open cart" title="Cart">
      <svg class="cart-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M3 4h2l2.2 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 7H7.2"></path>
        <circle cx="10" cy="19" r="1.6"></circle>
        <circle cx="17" cy="19" r="1.6"></circle>
      </svg>
      <span class="cart-count-badge">{{cartItemCount}}</span>
    </a>
    <nav class="navbar" id="primary-navbar">
      <a href="/">Home</a>
      <a href="/contact">Contact</a>
      <a href="/menu">Menu</a>
      <a href="/about">About</a>
      <a href="/services">Services</a>
      <a href="/gallery">Gallery</a>
      <a href="/others">Others</a>
      <a href="/login">Login</a>
      <a href="/cart" class="cart-nav-link" aria-label="Cart" title="Cart">
        <svg class="cart-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path d="M3 4h2l2.2 9.2a1 1 0 0 0 1 .8H18a1 1 0 0 0 1-.8L21 7H7.2"></path>
          <circle cx="10" cy="19" r="1.6"></circle>
          <circle cx="17" cy="19" r="1.6"></circle>
        </svg>
        <span class="cart-count-badge">{{cartItemCount}}</span>
      </a>
    </nav>
  </header>

  <main class="container">
    {{{body}}}
  </main>
  <button id="topBtn" class="top-btn" type="button" aria-label="Scroll to top">Top</button>
  <script>
    (() => {
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.navbar');
      const topBtn = document.getElementById('topBtn');

      const closeMenu = () => {
        if (!toggle || !nav) return;
        nav.classList.remove('is-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.classList.remove('is-open');
      };

      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const isOpen = nav.classList.toggle('is-open');
          toggle.classList.toggle('is-open', isOpen);
          toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        nav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            if (window.matchMedia('(max-width: 1024px)').matches) {
              closeMenu();
            }
          });
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 1024) {
            closeMenu();
          }
        });

        document.addEventListener('click', (event) => {
          if (!window.matchMedia('(max-width: 1024px)').matches) {
            return;
          }

          const clickedInsideMenu = nav.contains(event.target);
          const clickedToggle = toggle.contains(event.target);
          if (!clickedInsideMenu && !clickedToggle) {
            closeMenu();
          }
        });
      }

      const menuSections = document.querySelectorAll('.menu-section');
      if (menuSections.length) {
        const slugify = (value) =>
          String(value || '')
            .toLowerCase()
            .trim()
            .replace(/&/g, 'and')
            .replace(/[^a-z0-9]+/g, '-')
            .replace(/^-+|-+$/g, '');

        menuSections.forEach((section) => {
          const sectionToggle = section.querySelector('.menu-section-toggle');
          const sectionGrid = section.querySelector('.card-grid');
          const categoryName = section.dataset.category || sectionToggle?.innerText || '';

          if (!section.id && categoryName) {
            section.id = slugify(categoryName);
          }

          if (!sectionToggle || !sectionGrid) return;

          sectionToggle.addEventListener('click', () => {
            const isCollapsed = section.classList.toggle('is-collapsed');
            sectionToggle.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
          });
        });

        document.querySelectorAll('.menu-category-links a').forEach((link) => {
          link.addEventListener('click', (event) => {
            const targetId = link.getAttribute('href');
            if (!targetId || !targetId.startsWith('#')) return;
            const targetSection = document.querySelector(targetId);
            if (!targetSection) return;
            event.preventDefault();

            if (targetSection.classList.contains('is-collapsed')) {
              targetSection.classList.remove('is-collapsed');
              const targetToggle = targetSection.querySelector('.menu-section-toggle');
              if (targetToggle) {
                targetToggle.setAttribute('aria-expanded', 'true');
              }
            }

            targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

            const extraTargets = link.dataset.open;
            if (extraTargets) {
              extraTargets.split(',').forEach((slug) => {
                const extraSection = document.getElementById(slug.trim());
                if (!extraSection || !extraSection.classList.contains('is-collapsed')) return;
                extraSection.classList.remove('is-collapsed');
                const extraToggle = extraSection.querySelector('.menu-section-toggle');
                if (extraToggle) {
                  extraToggle.setAttribute('aria-expanded', 'true');
                }
              });
            }
          });
        });
      }

      if (topBtn) {
        const toggleTopBtn = () => {
          const shouldShow = window.scrollY > 240;
          topBtn.classList.toggle('is-visible', shouldShow);
        };

        window.addEventListener('scroll', toggleTopBtn, { passive: true });
        toggleTopBtn();

        topBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    })();
  </script>
</body>
</html>

